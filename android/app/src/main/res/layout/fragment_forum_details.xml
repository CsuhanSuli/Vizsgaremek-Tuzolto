<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvForumDetailHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Header"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:background="@android:color/darker_gray" />

        <TextView
            android:id="@+id/tvForumDetailType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Típus: Type Name"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvForumDetailPlace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Helyszín: Location"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Leírás:"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvForumDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Description goes here..."
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/adminForumActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnEditForum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Módosítás"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btnDeleteForumDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Törlés"
                android:backgroundTint="@android:color/holo_red_dark" />

        </LinearLayout>

        <Button
            android:id="@+id/btnBackToForum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Vissza"
            style="?attr/materialButtonOutlinedStyle" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>