<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvToolDetailName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tool Name"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvToolDetailPlace"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Helye: Place Name"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/tvToolDetailName"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvReviewLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Felülvizsgálatok:"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvToolDetailPlace"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewReviews"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/adminReviewActions"
        app:layout_constraintTop_toBottomOf="@id/tvReviewLabel" />

    <LinearLayout
        android:id="@+id/adminReviewActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btnNewReviewDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Új ellenőrzés dátum"
            android:backgroundTint="@color/design_default_color_primary" />

        <Button
            android:id="@+id/btnUpdateLatestReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Legutóbbi dátum módosítása"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/btnDeleteLatestReview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Legutóbbi törlése"
            android:backgroundTint="@android:color/holo_red_dark" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>